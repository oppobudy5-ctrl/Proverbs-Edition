    {
      "id": "dict-chokmah",
      "category": "Hebrew",
      "term": "חָכְמָה",
      "transliteration": "chokmah",
      "meaning": "hikmat, kecakapan",
      "definition": "Kemampuan praktis dan moral untuk menjalani hidup dengan terampil di hadapan Allah; mencakup keterampilan kerja, penilaian etis, dan kebijaksanaan hidup.",
      "references": ["Amsal 1:2", "Amsal 2:6", "Amsal 9:10"],
      "relatedTerms": ["binah", "musar", "daat"],
      "topics": ["wisdom"]
    },
    {
      "id": "dict-musar",
      "category": "Hebrew",
      "term": "מוּסָר",
      "transliteration": "musar",
      "meaning": "didikan, disiplin, teguran",
      "definition": "Pembentukan watak melalui pengajaran dan koreksi; bukan sekadar hukuman, tetapi proses membentuk kedewasaan moral.",
      "references": ["Amsal 1:2", "Amsal 3:11", "Amsal 13:24"],
      "relatedTerms": ["chokmah", "tokhachat"],
      "topics": ["discipline"]
    },
    {
