# Bible Time — Production AI Provider (Phase 006B)
# Copy to `.env` for local development. Never commit real secrets.

# Default provider: mock | openai | gemini | claude | azure | ollama
AI_PROVIDER=mock
AI_RUNTIME_MODE=development

# Optional comma-separated failover order
AI_FAILOVER_ORDER=openai,gemini,claude,azure,ollama,mock

AI_TEMPERATURE=0.35
AI_MAX_TOKENS=900
AI_STREAMING=true
AI_TIMEOUT_MS=30000
AI_OFFLINE_MODE=false

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (Claude adapter)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Azure OpenAI (optional)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Ollama (local — no key)
OLLAMA_BASE_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.2
